{
  "name": "txunos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "layers/core",
    "layers/browser",
    "layers/calculator",
    "layers/calendar",
    "layers/clock",
    "layers/dev-tools",
    "layers/file-manager",
    "layers/image-viewer",
    "layers/settings",
    "layers/sticky-notes",
    "layers/task-manager",
    "layers/terminal",
    "layers/text-editor",
    "layers/camera",
    "layers/music-player",
    "layers/video-player"
  ],
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:unit": "vitest --project unit",
    "test:nuxt": "vitest --project nuxt",
    "pack:workspaces": "npm pack --workspaces --dry-run",
    "publish:workspaces": "node scripts/publish-workspaces.mjs",
    "publish:workspaces:dry-run": "NPM_PUBLISH_DRY_RUN=true node scripts/publish-workspaces.mjs"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.102",
    "@iconify-json/simple-icons": "^1.2.78",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "4.0.2",
    "@nuxt/ui": "^4.6.1",
    "@nuxtjs/i18n": "10.3.0",
    "@pinia/nuxt": "^0.11.3",
    "eslint": "^10.2.1",
    "nuxt": "^4.4.2",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/w3c-web-serial": "^1.0.8",
    "@types/web-bluetooth": "^0.0.21",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.8",
    "happy-dom": "^20.9.0",
    "sass": "^1.99.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.6"
  },
  "volta": {
    "node": "24.12.0",
    "npm": "11.14.1"
  }
}
